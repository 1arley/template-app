# development@v2
# ==============================================
# SEEDABIT NESTJS TEMPLATE - Environment Variables
# ==============================================

# Node Environment
NODE_ENV=development
PORT=3000

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seedabit_db?schema=public

# ==============================================
# JWT CONFIGURATION
# ==============================================
# IMPORTANT: Change this secret in production!
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_ACCESS_SECRET=[INSIRA_TOKEN_ACESS_AQUI]
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=[INSIRA_TOKEN_REFRESH_AQUI]
JWT_REFRESH_EXPIRES_IN=7d
# ==============================================
# DOCKER CONFIGURATION
# ==============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seedabit_db

# pgAdmin Configuration
PGADMIN_EMAIL=admin@seedabit.com
PGADMIN_PASSWORD=admin

# ==============================================
# API CONFIGURATION
# ==============================================
API_PREFIX=api
SWAGGER_PATH=api/docs

# ==============================================
# CORS CONFIGURATION (Optional)
# ==============================================
# CORS_ORIGIN=http://localhost:3000,http://localhost:4200
# CORS_CREDENTIALS=true
